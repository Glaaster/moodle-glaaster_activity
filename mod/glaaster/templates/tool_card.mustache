{{!
    @template mod_glaaster/tool_card

    This template provides the layout for a single tool card on the tool
    configuration page.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * id
    * name
    * state
    ** pending|configured|rejected|unknown
    ** text
    * urls
    ** edit
    ** publickeyset
    ** accesstoken
    ** authrequest
    * platformid
    * clientid
    * deploymentid

    Example context (json):
    {
        "id": 1,
        "name": "Example Tool",
        "platformid": "https:\/\/moodle.example.com",
        "courseid": 0,
        "hascapabilitygroups": false,
        "state": {
            "text": "Active",
            "pending": false,
            "configured": true,
            "rejected": false,
            "unknown": false
        },
        "urls": {
            "edit": "https://www.example.com/mod/glaaster/typessettings.php",
            "publickeyset": "https:\/\/moodle.example.com\/mod\/glaaster\/certs.php",
            "accesstoken": "https:\/\/moodle.example.com\/mod\/glaaster\/token.php",
            "authrequest": "https:\/\/moodle.example.com\/mod\/glaaster\/auth.php"
        },
        "clientid": null,
        "deploymentid": 1
    }

}}
<div class="tool-card"
     data-type-id="{{id}}" data-uniqid="{{uniqid}}"
     data-platformid="{{platformid}}" data-clientid="{{clientid}}" data-deploymentid="{{deploymentid}}"
     data-publickeyseturl="{{urls.publickeyset}}" data-accesstokenurl="{{urls.accesstoken}}"
     data-authrequesturl="{{urls.authrequest}}" data-statusurl="{{statusurl}}">
    <div class="overlay-container">{{> mod_glaaster/loader }}</div>
    <div class="tool-card-header d-flex align-items-start justify-content-between mb-3">
        <div class="contenteditable-container flex-grow-1">
            <span class="name fw-semibold d-block mb-1" contenteditable="true">{{name}}</span>
            <div class="d-flex gap-1 flex-wrap">
                {{^state.configured}}
                    <span class="badge rounded-pill {{#state.pending}}bg-info text-white{{/state.pending}}{{#state.rejected}}bg-danger text-white{{/state.rejected}}{{#state.unknown}}bg-warning text-dark{{/state.unknown}}">{{state.text}}</span>
                {{/state.configured}}
                <span class="tool-connection-status badge rounded-pill d-none"></span>
            </div>
        </div>
        <div class="tool-card-actions d-flex gap-1 flex-shrink-0 ms-3">
            <a class="edit tool-card-btn" href="{{{urls.edit}}}" title="{{#str}} edit {{/str}}">
                {{#pix}}t/edit, core, {{#str}} edit {{/str}}{{/pix}}
            </a>
            <button class="delete tool-card-btn tool-card-btn-danger" type="button" title="{{#str}} delete, mod_glaaster {{/str}}">
                {{#pix}}t/delete, core, {{#str}} delete, mod_glaaster {{/str}}{{/pix}}
            </button>
        </div>
    </div>
</div>
{{#js}}
    require(['jquery', 'mod_glaaster/tool_card_controller'], function($, controller) {
    var cardElement = $('[data-type-id={{id}}]');
    controller.init(cardElement);
    });
{{/js}}
