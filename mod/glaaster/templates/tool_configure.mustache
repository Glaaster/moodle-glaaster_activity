{{!
    @template mod_glaaster/tool_configure

    This template provides the layout for the external tool configuration page in the
    LTI module.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    *

    Example context (json):
    {
        "configuremanualurl":"https://some.tool.example/mod/glaaster/typessettings.php?sesskey=OKl37bHflL&amp;returnto=toolconfigure",
        "managetoolsurl":"https://some.tool.example/admin/settings.php?section=modsettingglaaster",
        "managetoolproxiesurl":"https://some.tool.example/mod/glaaster/toolproxies.php"
    }

}}
<div id="main-content-container">
    <div id="registration-form-container" aria-live="polite">
        <div id="registration-feedback-container" aria-live="polite"></div>
        <div id="registration-choice-container" class="mb-4">
            <p class="text-muted">{{#str}} connect_glaaster_desc, mod_glaaster {{/str}}</p>
        </div>
        <div class="alert alert-info d-flex align-items-start mt-3" style="gap:12px;" role="alert">
            <span class="fa fa-info-circle mt-1 flex-shrink-0" aria-hidden="true"></span>
            <span>{{#str}} connect_support_info, mod_glaaster {{/str}}</span>
        </div>
        <div id="external-registration-container" aria-live="polite" class="hidden">
            {{> mod_glaaster/external_registration }}
        </div>
    </div>

</div>
{{#js}}
    require(['mod_glaaster/tool_configure_controller'], function(controller) {
    controller.init();
    });
{{/js}}
